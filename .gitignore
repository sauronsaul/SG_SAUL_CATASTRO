# ============================================================
# SG_SAUL_CATASTRO — .gitignore
# ============================================================

# ------------------------------------------------------------
# .NET / C#
# ------------------------------------------------------------
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.rsuser
*.dbmdl
*.jfm
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp_proj
*_wpftmp.csproj
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc
project.lock.json
project.fragment.lock.json
artifacts/
**/Properties/launchSettings.json
TestResults/
*.trx
coverage/
*.coverage
*.coveragexml

# ------------------------------------------------------------
# Node.js / Frontend
# ------------------------------------------------------------
node_modules/
dist/
.vite/
.cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ------------------------------------------------------------
# IDEs
# ------------------------------------------------------------
# VS Code — excluir configuración personal, conservar compartida
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# JetBrains / Rider
.idea/
*.iml
# Visual Studio
*.aps
*.ncb
*.opendb
# VS Code C# Dev Kit — caché del language server (generado automáticamente)
*.lscache

# ------------------------------------------------------------
# Docker — overrides locales de usuario (NO los variantes oficiales local/prod)
# ------------------------------------------------------------
docker-compose.override.yml
# datos de volúmenes si se montaran localmente
.docker/

# ------------------------------------------------------------
# Variables de entorno — NUNCA versionar .env real
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
log/

# ------------------------------------------------------------
# Sistema operativo
# ------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
*.lnk
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
# Linux
*~

# ------------------------------------------------------------
# Build outputs / publicación
# ------------------------------------------------------------
publish/
out/
*.nupkg
*.snupkg

# ------------------------------------------------------------
# Secretos y certificados
# ------------------------------------------------------------
*.pfx
*.p12
*.pem
*.key
*.crt
secrets/

# ------------------------------------------------------------
# Archivos temporales del proyecto
# ------------------------------------------------------------
*.tmp
*.bak
*.swp
*.orig
