http://:3000 {
	root * /srv

	@versionados path /_framework/* /lib/maplibre-gl/5.24.0/*
	header @versionados Cache-Control "public, max-age=31536000, immutable"

	@mutables {
		not path /_framework/* /lib/maplibre-gl/5.24.0/*
	}
	header @mutables Cache-Control "no-cache"

	try_files {path} /index.html
	file_server
}
