# ============================================================
# SG_SAUL_CATASTRO — Variables de entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como ".env" en la raíz del proyecto.
#   2. Reemplazar TODOS los valores marcados con <CAMBIAR>.
#   3. NUNCA versionar el archivo ".env" real (está en .gitignore).
#   4. Los comentarios explican el propósito de cada variable.
# ============================================================

# ------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------

# Usuario administrador de la base de datos
POSTGRES_USER=sg_admin

# Contraseña del usuario administrador.
# RESTRICCIÓN DE CARACTERES (ver ADR 0014): usar SOLO alfanumérico,
# guion (-), guion bajo (_) y punto (.). PROHIBIDO usar: ; = ' " espacio
# \ / @ { } ( ) [ ] < > ! ? & # $ ^ * ~ ` |
# Esos caracteres rompen el parser de connection strings de Npgsql.
#
# Comando sugerido para generar un password seguro y compatible:
#   PowerShell: -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 32 | % {[char]$_})
#   Linux/Mac:  LC_ALL=C tr -dc 'A-Za-z0-9_.-' </dev/urandom | head -c 32
POSTGRES_PASSWORD=<CAMBIAR_PASSWORD_SEGURO_SOLO_ALFANUM_GUION_PUNTO>

# Nombre de la base de datos principal
POSTGRES_DB=sg_catastro

# Puerto expuesto en el host (el contenedor siempre usa 5432 internamente).
# Por qué no 5432: las instalaciones locales de PostgreSQL 16 en Windows
#   ocupan ese puerto por defecto.
# Por qué no 5433: las instalaciones locales de PostgreSQL 17 en Windows
#   también usan 5433 como puerto por defecto.
# 5434 es el puerto sugerido para evitar ambos conflictos.
# Ver ADR 0017-conflicto-puerto-postgres.md.
POSTGRES_PORT=5434

# ------------------------------------------------------------
# MINIO (almacenamiento de documentos adjuntos)
# ------------------------------------------------------------

# Usuario root de MinIO (equivale a "access key")
MINIO_ROOT_USER=sg_minio_admin

# Contraseña root de MinIO — CAMBIAR en producción
MINIO_ROOT_PASSWORD=<CAMBIAR_PASSWORD_SEGURO>

# Puerto para la API S3 de MinIO
MINIO_API_PORT=9000

# Puerto para la consola web de administración de MinIO
MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------
# CONNECTION STRING .NET
# La doble barra baja (__) es la convención de IConfiguration para
# secciones anidadas. Esta variable sobreescribe ConnectionStrings:Default.
# Para desarrollo local (dotnet run): Host=localhost
# En Docker el host es el nombre del servicio (postgres)
# ------------------------------------------------------------

# IMPORTANTE:
# - Password= debe ser IDÉNTICO a POSTGRES_PASSWORD (ver ADR 0014).
# - Port= debe coincidir con POSTGRES_PORT.
# - Misma restricción de caracteres: solo alfanumérico, guion, underscore, punto.
ConnectionStrings__Default=Host=localhost;Port=5434;Database=sg_catastro;Username=sg_admin;Password=<MISMO_VALOR_QUE_POSTGRES_PASSWORD>;Pooling=true

# ------------------------------------------------------------
# BACKEND API (ASP.NET Core 10)
# ------------------------------------------------------------

# Entorno de ejecución: Development | Production
ASPNETCORE_ENVIRONMENT=Development

# Puerto expuesto en el host para la API
BACKEND_PORT=8080

# Clave secreta para firmar JWT — mínimo 32 caracteres, CAMBIAR
JWT_SECRET=<CAMBIAR_CLAVE_SECRETA_MINIMO_32_CARACTERES>

# Identificador del emisor del token JWT
JWT_ISSUER=sg-catastro-api

# Audiencia esperada del token JWT
JWT_AUDIENCE=sg-catastro-web

# Tiempo de expiración del access token en minutos (recomendado: 15)
JWT_EXPIRY_MINUTES=15

# Tiempo de expiración del refresh token en días (recomendado: 7)
REFRESH_TOKEN_EXPIRY_DAYS=7

# ------------------------------------------------------------
# FRONTEND (Vite + React)
# ------------------------------------------------------------

# Puerto expuesto en el host para el servidor de desarrollo / preview
FRONTEND_PORT=3000

# URL base de la API consumida por el frontend
# En modo local: http://localhost:8080
# En modo servidor: https://api.midominio.com
VITE_API_BASE_URL=http://localhost:8080

# ------------------------------------------------------------
# CADDY (reverse proxy)
# ------------------------------------------------------------

# Puerto HTTP del reverse proxy
CADDY_HTTP_PORT=80

# Puerto HTTPS del reverse proxy
CADDY_HTTPS_PORT=443

# Dominio para TLS automático (solo en modo servidor)
# En modo local: localhost
CADDY_DOMAIN=localhost
